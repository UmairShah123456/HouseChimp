# Copy to .env.local. For local dev, run `supabase start` and paste the printed values.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
# Server-only. Never expose to the client. Used for storage admin + magic-link token lookups that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Base URL used when generating guest magic links / QR codes.
NEXT_PUBLIC_APP_URL=http://localhost:3000
